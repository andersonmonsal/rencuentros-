# Configuración de Base de Datos PostgreSQL
DB_TYPE=postgres
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=your-username
DB_PASSWORD=your-password
DB_DATABASE=Encuentros
DB_SSL=true

# Configuración de JWT
# IMPORTANTE: En producción, usa una clave secreta fuerte y única
# Genera una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=encuentros_secret_key_2025_change_this_in_production

# Puerto del servidor
PORT=3000

# Entorno de ejecución
NODE_ENV=development
